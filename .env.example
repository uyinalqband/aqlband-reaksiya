# Supabase project settings (Settings -> API in the Supabase dashboard).
# The VITE_ prefix is required by Vite to expose these to client-side code.
# Only ever put the "anon" public key here — never the service_role key.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
